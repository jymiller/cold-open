# Copy to .env and fill what you have.
# Any blank key → that tool runs in OFFLINE demo mode. The loop still runs.

AKASHML_API_KEY=
AKASHML_MODEL=                                  # run `npm run models` to list, paste one verbatim
METAVIEW_API_KEY=                               # from https://my.metaview.app/settings/mcp
METAVIEW_MCP_URL=https://mcp.metaview.ai/mcp
POMERIUM_URL=                                   # optional real proxy; blank = local policy (same rules)
ZERO_ENABLED=                                   # set to 1 once zero is wired; blank = simulated buy
